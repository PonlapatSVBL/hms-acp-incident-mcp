# Required: Bearer token for api-acp (web-acp reads this from localStorage 'token').
ACP_API_TOKEN=your-jwt-token-here

# Optional: api-acp base URL. Defaults to the production base below.
ACP_API_BASE_URL=https://api.humansoft.co.th

# Optional: front-controller path. Defaults to /api.php.
ACP_API_PATH=/api.php

# Optional: current user's raw id. When set, identify_user_id=base64(id) is
# injected into every request. Omit if the backend derives it from the JWT.
ACP_USER_ID=

# Optional: per-request timeout in milliseconds (default 30000).
ACP_API_TIMEOUT_MS=30000
